# ============================================
# Sunbelt Electrical Diagnostic Tool - Config
# ============================================

# Anthropic API Key (required for AI diagnosis + vision analysis)
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model to use for diagnosis reasoning (text)
CLAUDE_MODEL=claude-opus-4-8

# Claude model to use for photo/vision analysis
CLAUDE_VISION_MODEL=claude-opus-4-8

# PostgreSQL Database connection
DATABASE_URL=postgresql://sunbelt_user:sunbelt_pass@db:5432/sunbelt_diag

# Flask secret key (change this for any real deployment)
FLASK_SECRET_KEY=change_this_to_a_random_secret_string

# Flask environment
FLASK_ENV=development
FLASK_DEBUG=1

# Upload settings
MAX_UPLOAD_SIZE_MB=15
UPLOAD_FOLDER=/app/uploads

# CORS - frontend origin allowed to call this API
FRONTEND_ORIGIN=http://localhost:3000

# Port the backend runs on
PORT=5000
